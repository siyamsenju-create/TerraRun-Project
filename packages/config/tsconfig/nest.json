{
  "extends": "./base.json",
  "compilerOptions": {
    "declaration": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": true,
    "strictPropertyInitialization": false
  },
  "exclude": ["node_modules", "dist"]
}

